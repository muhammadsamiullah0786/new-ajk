# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Random secure string — generate with: openssl rand -base64 32
ADMIN_JWT_SECRET="replace-with-a-long-random-secret"

# Used by prisma/seed.ts to create the first admin account
ADMIN_EMAIL="admin@ajkinsurance.com"
ADMIN_PASSWORD="ChangeMe123!"

# Email notifications (Resend — https://resend.com/api-keys)
RESEND_API_KEY="re_your_resend_api_key_here"
SUPPORT_EMAIL="support@ajkinssurance.com"
# Change to your verified domain once set up in Resend
EMAIL_FROM="AJK Leads <notifications@ajkinsurance.com>"

# Public site URL (used in email links)
NEXT_PUBLIC_SITE_URL="https://ajkinsurance.com"
